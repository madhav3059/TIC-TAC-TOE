/**
 * UC 6 - Place Move on Board
 * Updates the 2D array with the player's symbol at the specified indices.
 */
public class TicTacToe {

    public static void main(String[] args) {
        // Initialize an empty board
        char[][] board = {
            {'-', '-', '-'},
            {'-', '-', '-'},
            {'-', '-', '-'}
        };

        // Example: Player (X) chooses Row 1, Col 1
        int row = 1;
        int col = 1;
        char symbol = 'X';

        System.out.println("Placing '" + symbol + "' at [" + row + "][" + col + "]...");
        
        // Update the state
        placeMove(board, row, col, symbol);

        // Verify the update (visualizing the board)
        displayBoard(board);
    }

    /**
     * UC6 Method: State Update
     * This method is reusable for both Human and Computer players.
     */
    public static void placeMove(char[][] board, int row, int col, char symbol) {
        // Key Requirement: Update board correctly using Array Indexing
        board[row][col] = symbol;
        System.out.println("Board updated successfully.");
    }

    /**
     * Helper to show the result in the console
     */
    public static void displayBoard(char[][] board) {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(board[i][j] + " ");
            }
            System.out.println();
        }
    }
}
