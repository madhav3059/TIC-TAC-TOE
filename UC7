import java.util.Random;

/**
 * UC 7 - Computer Makes a Random Move (Easy Level)
 * The computer generates random moves until a valid one is found.
 */
public class TicTacToe {

    public static void main(String[] args) {
        // Sample board with some spots already taken
        char[][] board = {
            {'X', '-', 'O'},
            {'-', 'X', '-'},
            {'-', '-', '-'}
        };

        System.out.println("Computer is thinking...");
        computerMove(board, 'O');
        
        // Display result
        displayBoard(board);
    }

    /**
     * UC7 Method: Computer Player Logic
     * Uses Random Generation and a "Loop Until Valid" strategy.
     */
    public static void computerMove(char[][] board, char computerSymbol) {
        Random random = new Random();
        int slot;
        int row, col;
        boolean placed = false;

        // Loop Until Valid: Keep trying until an empty cell is found
        while (!placed) {
            // 1. Generate slot 1-9
            slot = random.nextInt(9) + 1; 

            // 2. Logic Reuse: Convert slot to indices (UC4 logic)
            row = (slot - 1) / 3;
            col = (slot - 1) % 3;

            // 3. Logic Reuse: Validate Move (UC5 logic)
            if (board[row][col] == '-') {
                // 4. Logic Reuse: Place Move (UC6 logic)
                board[row][col] = computerSymbol;
                System.out.println("Computer placed '" + computerSymbol + "' in slot " + slot);
                placed = true; // Exit the loop
            }
        }
    }

    /**
     * Reusable display method
     */
    public static void displayBoard(char[][] board) {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(board[i][j] + " ");
            }
            System.out.println();
        }
    }
}
