/**
 * UC 5 - Validate User Move
 * Ensures move is within bounds (0-2) and the cell is empty.
 */
public class TicTacToe {

    public static void main(String[] args) {
        // Sample Board (UC1)
        char[][] board = {
            {'-', 'X', '-'},
            {'-', '-', '-'},
            {'-', '-', '-'}
        };

        // Test Scenario: User tries to play at Row 0, Col 1 (Already has 'X')
        int row = 0;
        int col = 1;

        if (isValidMove(board, row, col)) {
            System.out.println("Move Accepted!");
        } else {
            System.out.println("Move Rejected: Invalid position or cell already occupied.");
        }
    }

    /**
     * UC5 Method: Performs validation using Conditional Logic
     * @return true if move is valid, false otherwise
     */
    public static boolean isValidMove(char[][] board, int row, int col) {
        
        // 1. Boundary Checking
        // Row and Column must be between 0 and 2
        if (row < 0 || row > 2 || col < 0 || col > 2) {
            System.out.println("Validation Error: Move is out of bounds!");
            return false;
        }

        // 2. Cell Occupancy Check
        // Cell must contain the placeholder '-' to be considered empty
        if (board[row][col] != '-') {
            System.out.println("Validation Error: Cell is already occupied!");
            return false;
        }

        // If both checks pass, the move is valid
        return true;
    }
}
